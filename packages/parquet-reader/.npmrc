cmake_js_out=dist/build
cmake_CMAKE_CXX_STANDARD=17
cmake_CMAKE_PROJECT_TOP_LEVEL_INCLUDES=cmake/conan_provider.cmake
# Current oldest supported version according to https://endoflife.date/macos
cmake_CMAKE_OSX_DEPLOYMENT_TARGET=11.0
cmake_CONAN_HOST_PROFILE="../../conan-profile"
cmake_CONAN_BUILD_PROFILE="../../conan-profile"
